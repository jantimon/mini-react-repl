{
  "name": "mini-react-repl",
  "version": "0.19.0",
  "description": "Browser-only React TSX REPL — multi-file editor, live preview, real Fast Refresh, no backend.",
  "keywords": [
    "fast-refresh",
    "import-map",
    "mini-repl",
    "monaco",
    "playground",
    "react",
    "react-playground",
    "react-repl",
    "repl",
    "sandbox",
    "swc",
    "tsx"
  ],
  "homepage": "https://github.com/jantimon/mini-react-repl#readme",
  "bugs": {
    "url": "https://github.com/jantimon/mini-react-repl/issues"
  },
  "license": "MIT",
  "author": "Jan Nicklas <j.nicklas@me.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jantimon/mini-react-repl.git"
  },
  "bin": {
    "repl-vendor-build": "./dist/vendor-builder/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./editor-monaco": {
      "types": "./dist/editor-monaco/index.d.ts",
      "node": "./dist/editor-monaco/index.node.js",
      "default": "./dist/editor-monaco/index.js"
    },
    "./inspect": {
      "types": "./dist/inspect/index.d.ts",
      "import": "./dist/inspect/index.js"
    },
    "./vendor-default": {
      "types": "./dist/vendor-default/index.d.ts",
      "import": "./dist/vendor-default/index.js"
    },
    "./vendor-base": {
      "types": "./dist/vendor-base.d.ts",
      "import": "./dist/vendor-base.js"
    },
    "./preview-html": {
      "types": "./dist/preview-html.d.ts",
      "import": "./dist/preview-html.js"
    },
    "./loader": {
      "types": "./dist/loader.d.ts",
      "import": "./dist/loader.js"
    },
    "./theme.css": "./dist/theme.css"
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && node scripts/build-runtime.mjs && node scripts/build-picker.mjs && node scripts/build-default-vendor.mjs && tsup && cp src/theme.css dist/theme.css",
    "build:lib": "tsup",
    "build:runtime": "node scripts/build-runtime.mjs",
    "build:picker": "node scripts/build-picker.mjs",
    "build:vendor": "node scripts/build-default-vendor.mjs",
    "dev": "pnpm --filter e2e-fixture dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p examples/e2e-fixture && tsc --noEmit -p examples/gh-pages && tsc --noEmit -p examples/custom-vendor && tsc --noEmit -p examples/virtual-modules && tsc --noEmit -p examples/transform && tsc --noEmit -p examples/starter",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.31",
    "@swc/wasm-web": "^1.15.30",
    "es-module-lexer": "^2.1.0",
    "react-refresh": "^0.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260426.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.20",
    "esbuild": "^0.28.0",
    "lodash-es": "^4.18.1",
    "monaco-editor": "^0.55.1",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "esbuild": ">=0.21",
    "monaco-editor": ">=0.45",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    },
    "monaco-editor": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.2"
}
