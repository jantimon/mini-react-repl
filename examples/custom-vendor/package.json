{
  "name": "custom-vendor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run build:vendor && vite",
    "build": "pnpm run build:vendor && vite build",
    "preview": "vite preview",
    "build:vendor": "repl-vendor-build src/vendor.entry.ts && repl-vendor-build src/vendor.entry.ts --out src/vendor.prod.generated --export-name prodVendor --prod --no-types",
    "postinstall": "pnpm run build:vendor || true"
  },
  "dependencies": {
    "@swc/wasm-web": "1.15.30",
    "mini-react-repl": "workspace:*",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "nanoid": "^5.1.9",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
