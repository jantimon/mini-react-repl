{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "dist",
    "node_modules",
    "examples/e2e-fixture/dist",
    "examples/gh-pages/dist",
    "test-results",
    "playwright-report",
    "src/runtime/runtime.bundled.ts",
    "src/inspect/picker.bundled.ts",
    "src/vendor-default/data-import-map.ts",
    "src/vendor-default/data-types.ts",
    "examples/*/src/vendor.generated"
  ],
  "semi": true,
  "singleQuote": true,
  "printWidth": 100,
  "trailingComma": "all",
  "arrowParens": "always",
  "endOfLine": "lf",
  "tabWidth": 2
}
