{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "dist",
    "node_modules",
    "examples/demo/dist",
    "test-results",
    "playwright-report",
    "src/runtime/runtime.bundled.ts",
    "src/vendor-default/data.ts"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn"
  },
  "rules": {
    "no-unused-vars": "off",
    "no-console": "off",
    "no-empty-pattern": "off",
    "eslint-plugin-unicorn/prefer-add-event-listener": "off",
    "eslint-plugin-unicorn/require-post-message-target-origin": "off",
    "eslint-plugin-unicorn/no-array-sort": "off",
    "no-await-in-loop": "off"
  }
}
